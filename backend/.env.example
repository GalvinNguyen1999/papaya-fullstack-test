# Postgres connection (local docker-compose default below)
DATABASE_URL="postgresql://papaya:papaya@localhost:5432/papaya?schema=public"

# CORS origin for the frontend (Vite/Next dev or your Vercel URL)
CORS_ORIGIN="http://localhost:3000"

# LLM provider chain (all optional). Order: OpenAI → Jina → template.
# Leave both empty to run in template mode (app still fully works).
#
# Jina is free: get a key at https://jina.ai (the DeepSearch API is OpenAI-compatible).
# After setting JINA_API_KEY below, verify it works in one command:
#   npm run llm:check
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
JINA_API_KEY=""
JINA_BASE_URL="https://deepsearch.jina.ai/v1"
JINA_MODEL="jina-deepsearch-v1"

PORT=4000
